#!/bin/bash
set -euo pipefail

if [[ ${1:-} == "--help" ]]; then
  printf 'Usage: elgato-preview\n\n'
  printf 'Opens the Elgato HD60 X as a 16:9 window suitable for Google Meet window sharing.\n\n'
  printf 'Environment overrides:\n'
  printf '  ELGATO_VIDEO_DEVICE=/dev/video0\n'
  printf '  ELGATO_VIDEO_SIZE=1920x1080\n'
  printf '  ELGATO_VIDEO_FPS=60\n'
  printf '  ELGATO_PREVIEW_WINDOW=1600x900\n'
  exit 0
fi

device=${ELGATO_VIDEO_DEVICE:-/dev/video0}
video_size=${ELGATO_VIDEO_SIZE:-1920x1080}
fps=${ELGATO_VIDEO_FPS:-60}
window_size=${ELGATO_PREVIEW_WINDOW:-1600x900}

if ! command -v ffplay >/dev/null 2>&1; then
  printf 'ffplay is required but was not found. Install ffmpeg first.\n' >&2
  exit 1
fi

if [[ ! -e $device ]]; then
  printf 'Elgato video device not found: %s\n' "$device" >&2
  exit 1
fi

if [[ $window_size != *x* ]]; then
  printf 'Invalid ELGATO_PREVIEW_WINDOW value: %s\n' "$window_size" >&2
  exit 1
fi

window_width=${window_size%x*}
window_height=${window_size#*x}

if [[ ! $window_width =~ ^[0-9]+$ || ! $window_height =~ ^[0-9]+$ ]]; then
  printf 'Invalid ELGATO_PREVIEW_WINDOW value: %s\n' "$window_size" >&2
  exit 1
fi

exec ffplay \
  -hide_banner \
  -loglevel warning \
  -fflags nobuffer \
  -flags low_delay \
  -framedrop \
  -f v4l2 \
  -input_format nv12 \
  -video_size "$video_size" \
  -framerate "$fps" \
  -window_title "Elgato HD60 X - Share this window" \
  -x "$window_width" \
  -y "$window_height" \
  "$device"
