#!/usr/bin/env bash

apply_monitor_rule() {
	hyprctl keyword monitor ",preferred,auto,1" >/dev/null 2>&1 || true
}

apply_monitor_pip() {
	hyprctl keyword monitor "HDMI-A-1,2560x1440@60,auto,1" >/dev/null 2>&1 || true
}

apply_monitor_ultrawide() {
	hyprctl keyword monitor "HDMI-A-1,3840x1080@59.97,auto,1" >/dev/null 2>&1 || true
}

main() {
	[[ -n ${XDG_RUNTIME_DIR:-} ]] || exit 0
	[[ -n ${HYPRLAND_INSTANCE_SIGNATURE:-} ]] || exit 0
	command -v hyprctl >/dev/null 2>&1 || exit 0

	case "${1:-}" in
	"" | --once | --preferred)
		apply_monitor_rule
		;;
	--pip | --half)
		apply_monitor_pip
		;;
	--ultrawide | --wide)
		apply_monitor_ultrawide
		;;
	*)
		apply_monitor_rule
		;;
	esac

	exit 0
}

main "$@"
