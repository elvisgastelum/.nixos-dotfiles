restart_process() {
	case "$1" in
	Hyprland) restart_service hyprland ;;
	Hypridle) restart_service hypridle ;;
	Hyprsunset) restart_service hyprsunset ;;
	Mako) restart_service mako ;;
	Walker) restart_service walker ;;
	Waybar) restart_service waybar ;;
	esac
}

show_restart_menu() {
	local selection
	selection=$(menu "Restart" "  Hyprland\n  Hypridle\n  Hyprsunset\n󰎟  Mako\n󰌧  Walker\n󰍜  Waybar")
	case "$selection" in
	*Hyprland*) restart_process Hyprland ;;
	*Hypridle*) restart_process Hypridle ;;
	*Hyprsunset*) restart_process Hyprsunset ;;
	*Mako*) restart_process Mako ;;
	*Walker*) restart_process Walker ;;
	*Waybar*) restart_process Waybar ;;
	esac
}

show_update_menu() {
	case "$(menu "Update" "  System\n󰔫  Channel [todo]\n  Config\n󰸌  Extra Themes [todo]\n  Process\n󰇅  Hardware [todo]\n  Firmware\n  Password\n  Timezone\n  Time")" in
	*System*) dotfiles open-floating-terminal dotfiles system update ;;
	*Channel*) unavailable "Update channel" ;;
	*Config*) open_config "$HOME/.config/waybar/config.jsonc" ;;
	*Themes*) unavailable "Extra theme update" ;;
	*Process*) show_restart_menu ;;
	*Hardware*) unavailable "Hardware restart presets" ;;
	*Firmware*) run_terminal_script "fwupdmgr refresh --force && fwupdmgr update --assume-yes; printf '\nPress enter to close...'; read -r _" ;;
	*Password*) dotfiles open-floating-terminal passwd ;;
	*Timezone*) dotfiles open-floating-terminal dotfiles system timezone ;;
	*Time*) run_terminal_script "sudo timedatectl set-ntp true; timedatectl; printf '\nPress enter to close...'; read -r _" ;;
	*) show_main_menu ;;
	esac
}

