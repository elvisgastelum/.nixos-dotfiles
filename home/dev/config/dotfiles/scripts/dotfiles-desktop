current_defaults_text() {
	local browser terminal editor

	browser=${DOTFILES_BROWSER_DESKTOP:-}
	if [[ -z $browser ]] && command_present xdg-settings; then
		browser=$(xdg-settings get default-web-browser 2>/dev/null || true)
	fi
	terminal=$(sed -n '/^[^#[:space:]]/ {p; q}' "${XDG_CONFIG_HOME:-$HOME/.config}/xdg-terminals.list" 2>/dev/null || true)
	editor=${EDITOR:-nvim}

	printf 'Browser: %s\nTerminal: %s\nEditor: %s\n' "${browser:-unknown}" "${terminal:-unknown}" "$editor"
}

show_defaults_menu() {
	local selection value defaults

	selection=$(menu "Defaults" "  Browser\n  Terminal\n  Editor\n  Show Current")
	case "$selection" in
	*Browser*)
		value=$(input "Browser desktop ID or command")
		[[ -n $value ]] && set_default browser "$value"
		;;
	*Terminal*)
		value=$(input "Terminal desktop ID or command")
		[[ -n $value ]] && set_default terminal "$value"
		;;
	*Editor*)
		value=$(input "Editor command")
		[[ -n $value ]] && set_default editor "$value"
		;;
	*Current*)
		defaults=$(current_defaults_text)
		menu "Defaults" "$defaults" 520 240 >/dev/null
		;;
	*) show_setup_menu ;;
	esac
}

show_setup_menu() {
	case "$(menu "Setup" "  Audio\n  Wifi\n󰂯  Bluetooth\n󱐋  Power Profile [todo]\n  System Sleep [todo]\n󰍹  Monitors\n  Keybindings\n  Input\n  Defaults\n󰱔  DNS [todo]\n  Security [todo]\n  Config")" in
