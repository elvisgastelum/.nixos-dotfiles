	fi
}

restart_walker() {
	pkill -f 'walker --gapplication-service' 2>/dev/null || true
	run_background env GSK_RENDERER=cairo walker --gapplication-service
}

restart_waybar() {
	local status

	if waybar_lock_run restart_waybar_locked; then
		return 0
	else
		status=$?
	fi

	if (( status == 2 )); then
		die 'Waybar action already in progress.' 1
	fi

	return "$status"
}

restart_waybar_locked() {
	if ! stop_waybar; then
		return 1
	fi
	run_background waybar
	wait_for_waybar_start
}

restart_service() {
	local target="${1:-}"

	[[ -n $target ]] || die 'Usage: dotfiles restart <service>' 2

	case "$target" in
	alacritty | foot | ghostty | kitty | terminal)
		[[ -f ~/.config/alacritty/alacritty.toml ]] && touch ~/.config/alacritty/alacritty.toml
		pkill -SIGUSR1 kitty 2>/dev/null || true
		pkill -SIGUSR2 ghostty 2>/dev/null || true
		;;
	btop)
		pkill -SIGUSR2 btop 2>/dev/null || true
		;;
	hypr | hyprctl | hyprland)
		hyprctl reload
		;;
	hypridle)
		pkill -x hypridle 2>/dev/null || true
		run_background hypridle
		;;
	hyprsunset)
		pkill -x hyprsunset 2>/dev/null || true
		run_background hyprsunset
		;;
	mako)
		makoctl reload
		;;
	swayosd)
		pkill -x swayosd-server 2>/dev/null || true
		run_background swayosd-server
		;;
	tmux)
		if pgrep -x tmux >/dev/null; then
			tmux source-file ~/.config/tmux/tmux.conf
		fi
		;;
	walker)
		restart_walker
		;;
	waybar)
		restart_waybar
		;;
	*)
		die "Unknown restart target: $target" 2
		;;
	esac
}

trim_whitespace() {
	local value="$1"
	value="${value#"${value%%[![:space:]]*}"}"
	value="${value%"${value##*[![:space:]]}"}"
	printf '%s' "$value"
}

toml_string_value() {
	local file="$1" section="$2" key="$3"
	local line in_section=0

	[[ -f $file ]] || return 1
	[[ -z $section ]] && in_section=1

	while IFS= read -r line || [[ -n $line ]]; do
		if [[ -n $section ]]; then
			if [[ $line =~ ^[[:space:]]*\[$section\][[:space:]]*($|#) ]]; then
				in_section=1
				continue
			fi

			if [[ $line =~ ^[[:space:]]*\[[^]]+\] ]]; then
				in_section=0
				continue
			fi
		fi

		if ((in_section)) && [[ $line =~ ^[[:space:]]*$key[[:space:]]*=[[:space:]]*\"([^\"]*)\" ]]; then
			printf '%s\n' "${BASH_REMATCH[1]}"
			return 0
		fi
	done <"$file"

	return 1
}

ratune_server_identity() {
	local config_dir config_file cache_file url username

	config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/ratune"
	config_file="$config_dir/config.toml"
	cache_file="$config_dir/server.local.toml"
	url="${TERMUSIC_SUBSONIC_URL:-${SUBSONIC_URL:-}}"
	username="${TERMUSIC_SUBSONIC_USER:-${SUBSONIC_USER:-}}"

	if [[ -z $url ]]; then
		url=$(toml_string_value "$config_file" server url || true)
	fi
	if [[ -z $username ]]; then
		username=$(toml_string_value "$config_file" server username || true)
	fi
	if [[ -z $url ]]; then
		url=$(toml_string_value "$cache_file" "" url || true)
	fi
	if [[ -z $username ]]; then
		username=$(toml_string_value "$cache_file" "" username || true)
	fi

	url=$(trim_whitespace "$url")
	username=$(trim_whitespace "$username")
	while [[ $url == */ ]]; do
		url=${url%/}
	done

	if [[ -z $url || -z $username ]]; then
		die "Ratune server identity is missing. Set [server].url and [server].username in $config_file, create $cache_file, or export SUBSONIC_URL and SUBSONIC_USER." 2
	fi

	printf '%s\n%s\n' "$url" "$username"
}

reset_ratune() {
	local url username label description persistent_keyring keyring key_id found=0
	local -a identity keyrings

	if [[ $# -ne 0 ]]; then
		die 'Usage: dotfiles reset ratune' 2
	fi
	if [[ $(uname -s) != Linux ]]; then
		die 'dotfiles reset ratune only supports Linux keyutils.' 2
	fi
	command_present keyctl || die 'keyctl is required to reset Ratune keyutils credentials. Install the keyutils package.' 127

	mapfile -t identity < <(ratune_server_identity)
	url=${identity[0]}
	username=${identity[1]}
	label="$url|$username"
	description="keyring:${label}@ratune"
	keyrings=(@s)

	if persistent_keyring=$(keyctl get_persistent @s 2>/dev/null); then
		keyrings+=("$persistent_keyring")
	fi

	for keyring in "${keyrings[@]}"; do
		if key_id=$(keyctl search "$keyring" user "$description" 2>/dev/null); then
			keyctl invalidate "$key_id"
			found=1
		fi
	done

	if ((found)); then
		printf 'Reset Ratune Subsonic password key for %s (%s).\n' "$username" "$url"
	else
		printf 'No Ratune keyutils password key found for %s (%s).\n' "$username" "$url"
	fi

	printf 'Run ratune again in a TTY and enter the correct Subsonic password when prompted.\n'
}

menu() {
	local prompt="$1"
	local options="$2"
	local width="${3:-$MENU_WIDTH}"
	local height="${4:-$MENU_HEIGHT}"

	printf '%b\n' "$options" |
		dotfiles walker --dmenu --width "$width" --minheight 1 --maxheight "$height" -p "$prompt..." 2>/dev/null || true
}

menu_lines() {
	local prompt="$1"
	local width="${2:-$MENU_WIDTH}"
	local height="${3:-$MENU_HEIGHT}"
	shift 3 || true

	printf '%s\n' "$@" |
		dotfiles walker --dmenu --width "$width" --minheight 1 --maxheight "$height" -p "$prompt..." 2>/dev/null || true
}

input() {
	local prompt="$1"
	dotfiles input "$prompt" --width "$MENU_WIDTH" 2>/dev/null || true
}

open_url() {
	local name="$1"
	local url="$2"
	dotfiles open-web-app "$name" "$url"
}

open_config() {
	local file="$1"
	dotfiles edit "$file"
}

run_terminal_script() {
	dotfiles open-floating-terminal bash -lc "$1"
}

unavailable() {
	notify "Not implemented" "$1 is tracked in todo.txt for triage."
}

install_packages() {
	local label="$1"
	shift
	local command_line
	command_line=$(shell_join sudo pacman -S --needed "$@")
	run_terminal_script "printf 'Installing %s...\n' $(printf '%q' "$label"); $command_line; printf '\nPress enter to close...'; read -r _"
}

aur_helper() {
	if command_present paru; then
		printf '%s\n' paru
	elif command_present yay; then
		printf '%s\n' yay
	else
		return 1
	fi
}

install_aur_packages() {
	local helper label command_line
	label="$1"
	shift
	helper=$(aur_helper || true)
	if [[ -z $helper ]]; then
		notify "Cannot install AUR package" "paru or yay is required."
		return 1
	fi

	command_line=$(shell_join "$helper" -S --needed "$@")
	run_terminal_script "printf 'Installing %s...\n' $(printf '%q' "$label"); $command_line; printf '\nPress enter to close...'; read -r _"
}

remove_packages_by_name() {
	local command_line
	command_line=$(shell_join sudo pacman -Rns "$@")
	run_terminal_script "$command_line; printf '\nPress enter to close...'; read -r _"
}

desktop_prefix() {
	case "$1" in
	tui) printf '%s\n' dotfiles-tui ;;
	webapp) printf '%s\n' dotfiles-webapp ;;
	*) return 1 ;;
	esac
}

desktop_options() {
	local kind="$1"
	local prefix file name options=""

	prefix=$(desktop_prefix "$kind")
	shopt -s nullglob
	for file in "$APP_DIR"/"$prefix"-*.desktop; do
		name=$(desktop_value "$file" Name || true)
		[[ -n $name ]] && options="${options:+$options\n}$name"
	done
	shopt -u nullglob

	printf '%b' "$options"
}

desktop_file_for_selection() {
	local kind="$1"
	local selection="$2"
	local prefix file name

	prefix=$(desktop_prefix "$kind")
	shopt -s nullglob
	for file in "$APP_DIR"/"$prefix"-*.desktop; do
		name=$(desktop_value "$file" Name || true)
		if [[ $name == "$selection" ]]; then
			printf '%s\n' "$file"
			shopt -u nullglob
			return 0
		fi
	done
	shopt -u nullglob

	return 1
}

select_desktop_file() {
	local kind="$1"
	local prompt="$2"
	local options selection

	options=$(desktop_options "$kind")
	if [[ -z $options ]]; then
		notify "No ${kind} apps" "Add one from the dotfiles menu."
		return 1
	fi

	selection=$(menu "$prompt" "$options" 520)
	[[ -n $selection ]] || return 1

	desktop_file_for_selection "$kind" "$selection"
}

write_desktop_file() {
	local file="$1"
	local name="$2"
	local comment="$3"
	local exec_line="$4"
	local icon="$5"
	local category="$6"

	mkdir -p "$APP_DIR"
	cat >"$file" <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=$name
Comment=$comment
Exec=$exec_line
Icon=$icon
Terminal=false
Categories=$category
StartupNotify=false
EOF
}

create_tui_app_values() {
	local name="$1"
	local command="$2"
	local icon="${3:-utilities-terminal}"
	local slug file exec_line

	slug=$(slugify "$name")
	if [[ -z $slug ]]; then
		notify "Invalid app name" "$name"
		return 1
	fi

	file="$APP_DIR/dotfiles-tui-$slug.desktop"
	exec_line=$(shell_join dotfiles open-tui bash -lc "$command")
	write_desktop_file "$file" "$name" "Terminal UI app managed by dotfiles" "$exec_line" "$icon" "Utility;"
	notify "TUI app added" "$name"
	printf '%s\n' "$file"
}

create_web_app_values() {
	local name="$1"
	local url="$2"
	local icon="${3:-web-browser}"
	local slug file exec_line

	if [[ ! $url =~ ^[a-zA-Z][a-zA-Z0-9+.-]*: ]]; then
		url="https://$url"
	fi

	slug=$(slugify "$name")
	if [[ -z $slug ]]; then
		notify "Invalid app name" "$name"
		return 1
	fi

	file="$APP_DIR/dotfiles-webapp-$slug.desktop"
	exec_line=$(shell_join dotfiles open-or-focus-web-app "$name" "$url")
	write_desktop_file "$file" "$name" "Web app managed by dotfiles" "$exec_line" "$icon" "Network;WebBrowser;"
	notify "Web app added" "$name"
	printf '%s\n' "$file"
}

create_tui_app() {
	local name command icon

	if (($# >= 2)); then
		create_tui_app_values "$1" "$2" "${3:-utilities-terminal}"
		return
	fi

	name=$(input "TUI app name")
	[[ -n $name ]] || return 0

	command=$(input "Launch command")
	[[ -n $command ]] || return 0

	icon=$(input "Icon name")
	[[ -n $icon ]] || icon="utilities-terminal"

	create_tui_app_values "$name" "$command" "$icon" >/dev/null
}

create_web_app() {
	local name url icon

	if (($# >= 2)); then
		create_web_app_values "$1" "$2" "${3:-web-browser}"
		return
	fi

	name=$(input "Web app name")
	[[ -n $name ]] || return 0

	url=$(input "Web app URL")
	[[ -n $url ]] || return 0

	icon=$(input "Icon name")
	[[ -n $icon ]] || icon="web-browser"

	create_web_app_values "$name" "$url" "$icon" >/dev/null
}

remove_desktop_app() {
	local kind="$1"
	local file name confirmation

	file=$(select_desktop_file "$kind" "Remove") || return 0
	name=$(desktop_value "$file" Name || basename "$file")
	confirmation=$(menu_lines "Remove $name" "$MENU_WIDTH" 180 "Remove" "Cancel")

	if [[ $confirmation == "Remove" ]]; then
		rm -f "$file"
		notify "Removed" "$name"
	fi
}

show_tui_menu() {
	local apps selection file

	apps=$(desktop_options tui)
	selection=$(menu "TUI Apps" "${apps:+$apps\n}Add TUI App\nRemove TUI App" 520)

	case "$selection" in
	"Add TUI App") create_tui_app ;;
	"Remove TUI App") remove_desktop_app tui ;;
	"") show_main_menu ;;
	*)
		file=$(desktop_file_for_selection tui "$selection" || true)
		[[ -n $file ]] && launch_desktop_file "$file"
		;;
	esac
}

show_webapp_menu() {
	local apps selection file

	apps=$(desktop_options webapp)
	selection=$(menu "Web Apps" "${apps:+$apps\n}Add Web App\nRemove Web App" 520)

	case "$selection" in
	"Add Web App") create_web_app ;;
	"Remove Web App") remove_desktop_app webapp ;;
	"") show_main_menu ;;
	*)
		file=$(desktop_file_for_selection webapp "$selection" || true)
		[[ -n $file ]] && launch_desktop_file "$file"
		;;
	esac
}

install_pacman_package() {
	if ! command_present pacman || ! command_present fzf; then
		notify "Cannot install package" "pacman and fzf are required."
		return 1
	fi

	dotfiles open-floating-terminal bash -lc 'set -euo pipefail; packages=$(pacman -Slq | fzf --multi --prompt="Pacman> " || true); if [[ -n ${packages:-} ]]; then sudo pacman -S --needed $packages; fi; printf "\nPress enter to close..."; read -r _'
}

install_aur_package() {
	local helper

	helper=$(aur_helper || true)
	if [[ -z $helper ]] || ! command_present fzf; then
		notify "Cannot install AUR package" "yay or paru and fzf are required."
		return 1
	fi

	dotfiles open-floating-terminal bash -lc "set -euo pipefail; packages=\$($helper -Slqa | fzf --multi --prompt='AUR> ' || true); if [[ -n \${packages:-} ]]; then $helper -S --needed \$packages; fi; printf '\nPress enter to close...'; read -r _"
}

remove_package() {
	if ! command_present pacman || ! command_present fzf; then
		notify "Cannot remove package" "pacman and fzf are required."
		return 1
	fi

	dotfiles open-floating-terminal bash -lc 'set -euo pipefail; packages=$(pacman -Qqe | fzf --multi --prompt="Remove> " || true); if [[ -n ${packages:-} ]]; then sudo pacman -Rns $packages; fi; printf "\nPress enter to close..."; read -r _'
}

show_apps_menu() {
	case "$(menu "Apps" "󰀻  Launcher\n  TUI Apps\n  Web Apps")" in
	*Launcher*) dotfiles walker ;;
	*TUI*) show_tui_menu ;;
	*Web*) show_webapp_menu ;;
	*) show_main_menu ;;
	esac
}

show_learn_menu() {
	case "$(menu "Learn" "  Keybindings\n  Dotfiles\n  Hyprland\n󰣇  Arch\n  Neovim\n󱆃  Bash")" in
	*Keybindings*) show_keybindings ;;
	*Dotfiles*) open_url Dotfiles "https://github.com/elvisgastelum/dotfiles" ;;
	*Hyprland*) open_url Hyprland "https://wiki.hypr.land/" ;;
	*Arch*) open_url Arch "https://wiki.archlinux.org/title/Main_page" ;;
	*Neovim*) open_url Neovim "https://www.lazyvim.org/keymaps" ;;
	*Bash*) open_url Bash "https://devhints.io/bash" ;;
	*) show_main_menu ;;
	esac
}

set_reminder() {
	local minutes message pid file
	minutes=$(input "Remind in minutes")
	if [[ ! $minutes =~ ^[0-9]+$ ]] || ((minutes <= 0)); then
		[[ -n $minutes ]] && notify "Invalid reminder" "Enter the number of minutes."
		return 0
	fi

	message=$(input "Reminder message")
	[[ -n $message ]] || message="Reminder"
	mkdir -p "$STATE_DIR/reminders"
	(
		sleep "${minutes}m"
		notify-send "󰔛  Reminder" "$message" 2>/dev/null || true
		rm -f "$STATE_DIR/reminders/$BASHPID"
	) &
	pid=$!
	file="$STATE_DIR/reminders/$pid"
	printf '%s\t%s\t%s\n' "$pid" "$minutes" "$message" >"$file"
	notify "Reminder set" "$message in $minutes minutes"
}

show_reminders() {
	local options="" file pid minutes message
	mkdir -p "$STATE_DIR/reminders"
	shopt -s nullglob
	for file in "$STATE_DIR"/reminders/*; do
		IFS=$'\t' read -r pid minutes message <"$file" || true
		if [[ -n ${pid:-} ]] && kill -0 "$pid" 2>/dev/null; then
			options="${options:+$options\n}󰔛  ${message:-Reminder} (${minutes:-?}m)"
		else
			rm -f "$file"
		fi
	done
	shopt -u nullglob
	[[ -n $options ]] || options="No reminders"
	menu "Reminders" "$options" 520 320 >/dev/null
}

clear_reminders() {
	local file pid
	mkdir -p "$STATE_DIR/reminders"
	shopt -s nullglob
	for file in "$STATE_DIR"/reminders/*; do
		IFS=$'\t' read -r pid _ <"$file" || true
		[[ -n ${pid:-} ]] && kill "$pid" 2>/dev/null || true
		rm -f "$file"
	done
	shopt -u nullglob
	notify "Reminders cleared"
}

show_reminder_menu() {
	case "$(menu "Reminder" "󰔛  Set one\n󰔛  Show all\n󰔛  Clear all")" in
	*Set*) set_reminder ;;
	*"Show all"*) show_reminders ;;
	*"Clear all"*) clear_reminders ;;
	*) show_trigger_menu ;;
	esac
}

