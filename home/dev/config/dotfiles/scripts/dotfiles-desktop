power_menu() {
	local selection

	selection=$(printf 'Lock\nSuspend\nLogout\nReboot\nShutdown\n' | dotfiles walker --dmenu --width 420 --minheight 1 --maxheight 300 -p Power 2>/dev/null || true)

	case "$selection" in
	Lock) dotfiles system lock ;;
	Suspend) systemctl suspend ;;
	Logout) hyprctl dispatch exit ;;
	Reboot) systemctl reboot ;;
	Shutdown) systemctl poweroff ;;
	esac
}

show_keybindings() {
	if ! command_present hyprctl || ! command_present jq; then
		notify "Cannot show keybindings" "hyprctl and jq are required."
		return 1
	fi

	local monitor_height menu_height
	monitor_height=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .height' 2>/dev/null | head -n1)
	[[ $monitor_height =~ ^[0-9]+$ ]] || monitor_height=1200
	menu_height=$((monitor_height * 40 / 100))

	hyprctl -j binds |
		jq -r '
def mods:
  if . == 0 then ""
  elif . == 1 then "SHIFT"
  elif . == 4 then "CTRL"
  elif . == 5 then "SHIFT CTRL"
  elif . == 8 then "ALT"
  elif . == 9 then "SHIFT ALT"
  elif . == 12 then "CTRL ALT"
  elif . == 13 then "SHIFT CTRL ALT"
  elif . == 64 then "CMD"
  elif . == 65 then "CMD SHIFT"
  elif . == 68 then "CMD CTRL"
  elif . == 69 then "CMD SHIFT CTRL"
  elif . == 72 then "CMD ALT"
  elif . == 73 then "CMD SHIFT ALT"
  elif . == 76 then "CMD CTRL ALT"
  elif . == 77 then "CMD SHIFT CTRL ALT"
  else tostring
  end;
def key_name:
  if (.key // "") != "" then .key
  elif (.keycode // 0) != 0 then "code:\(.keycode)"
  elif (.mouse // 0) != 0 then "mouse:\(.mouse)"
  else ""
  end;
.[] |
  ((.modmask | mods) as $mods |
  (key_name) as $key |
  ([($mods | split(" ")[]?), $key] | map(select(. != "")) | join(" + ")) as $combo |
  ((.description // "") as $description |
  if $description != "" then $description else ([.dispatcher, .arg] | map(select(. != null and . != "")) | join(" ")) end) as $action |
  select($combo != "" and $action != "") |
  "\($combo) -> \($action)")' |
		sort -u |
		dotfiles walker --dmenu --width 800 --height "$menu_height" -p Keybindings >/dev/null 2>&1 || true
}

window_close_all() {
	hyprctl clients -j | jq -r '.[].address' | while read -r address; do
		[[ -n $address ]] && hyprctl dispatch closewindow "address:$address" >/dev/null
	done
}

