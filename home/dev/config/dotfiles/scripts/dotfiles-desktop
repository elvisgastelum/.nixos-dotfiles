	hyprctl dispatch togglefloating active
	hyprctl dispatch pin active
	hyprctl dispatch tagwindow +pop
}

workspace_layout_toggle() {
	local layout

	layout=$(hyprctl getoption general:layout -j | jq -r '.str')
	if [[ $layout == scrolling ]]; then
		hyprctl keyword general:layout dwindle
		notify "Layout: dwindle"
	else
		hyprctl keyword general:layout scrolling
		notify "Layout: scrolling"
	fi
}

monitor_scaling_cycle() {
	notify "Monitor scaling" "Edit ~/.config/hypr/monitors.conf and run hyprctl reload"
}

update_available() {
	local pacman_count=0 aur_count=0 total=0 helper tooltip

	if command_present checkupdates; then
		pacman_count=$(checkupdates 2>/dev/null | wc -l)
		pacman_count=${pacman_count//[[:space:]]/}
	fi

	if command_present paru; then
		helper=paru
	elif command_present yay; then
		helper=yay
	else
		helper=""
	fi

	if [[ -n $helper ]]; then
		aur_count=$($helper -Qua 2>/dev/null | wc -l)
		aur_count=${aur_count//[[:space:]]/}
	fi

	total=$((pacman_count + aur_count))
	if ((total > 0)); then
		tooltip="$total updates available ($pacman_count repo, $aur_count AUR)"
		printf '{"text":"","tooltip":"%s","class":"available"}\n' "$tooltip"
		return
	fi

	printf '{"text":"","tooltip":"","class":"none"}\n'
}

system_update() {
	local status
	local updater=()

	if command_present paru; then
		updater=(paru -Syu --noconfirm --skipreview --removemake)
	elif command_present yay; then
		updater=(yay -Syu --noconfirm --answerclean None --answerdiff None --answeredit None --answerupgrade None --removemake)
	elif command_present pacman; then
		updater=(sudo pacman -Syu --noconfirm)
	else
		printf 'No supported system updater found.\n' >&2
		exit 1
	fi

	set +e
	"${updater[@]}"
	status=$?
	set -e

	pkill -RTMIN+7 waybar 2>/dev/null || true
	return "$status"
}

system_timezone() {
	local timezone

	if ! command_present timedatectl; then
		printf 'timedatectl is required to select a timezone.\n' >&2
		return 1
	fi

	if command_present gum; then
		timezone=$(timedatectl list-timezones | gum filter --height 20 --header "Set timezone") || return 1
	elif command_present fzf; then
		timezone=$(timedatectl list-timezones | fzf --height 20 --prompt="Set timezone> ") || return 1
	else
		printf 'gum or fzf is required to select a timezone.\n' >&2
		return 1
	fi

	[[ -n $timezone ]] || return 0
	sudo timedatectl set-timezone "$timezone"
	printf 'Timezone is now set to %s\n' "$timezone"
	restart_waybar
}

voxtype_status() {
	if ! command_present voxtype; then
		printf '{"text":""}\n'
		return
	fi

	voxtype status --json 2>/dev/null || printf '{"text":""}\n'
}

