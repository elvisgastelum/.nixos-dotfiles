	*Wifi*) dotfiles control wifi ;;
	*Bluetooth*) dotfiles control bluetooth ;;
	*Power*) unavailable "Power profile selector" ;;
	*System*) unavailable "System sleep setup" ;;
	*Monitors*) open_config "$HOME/.config/hypr/monitors.conf" ;;
	*Keybindings*) open_config "$HOME/.config/hypr/bindings.conf" ;;
	*Input*) open_config "$HOME/.config/hypr/input.conf" ;;
	*Defaults*) show_defaults_menu ;;
	*DNS*) unavailable "DNS setup" ;;
	*Security*) unavailable "Security setup" ;;
	*Config*) open_config "$HOME/.config/hypr/hyprland.conf" ;;
	*) show_main_menu ;;
	esac
}

show_about() {
	dotfiles open-floating-terminal bash -lc 'fastfetch 2>/dev/null || uname -a; printf "\nPress enter to close..."; read -r _'
}

show_main_menu() {
	case "$(menu "Go" "󰀻  Apps\n󰧑  Learn\n󱓞  Trigger\n  Style\n  Setup\n󰉉  Install\n󰭌  Remove\n  Update\n  About\n  System")" in
	*Apps*) show_apps_menu ;;
	*Learn*) show_learn_menu ;;
	*Trigger*) show_trigger_menu ;;
	*Style*) show_style_menu ;;
	*Setup*) show_setup_menu ;;
	*Install*) show_install_menu ;;
	*Remove*) show_remove_menu ;;
	*Update*) show_update_menu ;;
	*About*) show_about ;;
	*System*) show_system_menu ;;
	esac
}

toggle_existing_menu() {
	if pgrep -f 'walker.*--dmenu' >/dev/null; then
		walker --close >/dev/null 2>&1 || true
		exit 0
	fi
}

menu_command() {
	if [[ $# -eq 0 ]]; then
		toggle_existing_menu
	fi

	case "${1:-}" in
	apps) show_apps_menu ;;
	keybindings) show_keybindings ;;
	learn) show_learn_menu ;;
	trigger) show_trigger_menu ;;
	style) show_style_menu ;;
	setup) show_setup_menu ;;
	tui | tuis) show_tui_menu ;;
	web | webapp | webapps) show_webapp_menu ;;
	install) show_install_menu ;;
	remove) show_remove_menu ;;
	update) show_update_menu ;;
	about) show_about ;;
	system | power) show_system_menu ;;
	defaults) show_defaults_menu ;;
	"") show_main_menu ;;
	*) show_main_menu ;;
	esac
}

capture_command() {
	case "${1:-}" in
	screenshot) capture_screenshot ;;
	screenrecording | screenrecord) capture_screenrecording ;;
	*) die 'Usage: dotfiles capture screenshot|screenrecording' 2 ;;
	esac
}

toggle_command() {
	case "${1:-}" in
	waybar | topbar) toggle_waybar ;;
	idle | idle-lock) toggle_idle ;;
	nightlight | night-light) toggle_nightlight ;;
	notifications | notification-silencing) toggle_notifications ;;
	touchpad)
		shift
		toggle_touchpad "$@"
		;;
	*) die 'Usage: dotfiles toggle waybar|idle|nightlight|notifications|touchpad' 2 ;;
	esac
}

status_command() {
	case "${1:-}" in
	"") managed_chezmoi status ;;
	battery) battery_status ;;
	updates | update-available) update_available ;;
	voxtype) voxtype_status ;;
	*)
		if managed_app_target "$1" >/dev/null; then
			managed_chezmoi status "$1"
		else
			die 'Usage: dotfiles status [app]|battery|updates|voxtype' 2
		fi
		;;
	esac
}

reset_command() {
	case "${1:-}" in
	ratune)
		shift
		reset_ratune "$@"
		;;
	*) die 'Usage: dotfiles reset ratune' 2 ;;
	esac
}

control_command() {
	case "${1:-}" in
	wifi) launch_wifi ;;
	bluetooth) launch_bluetooth ;;
	audio) launch_audio ;;
	*) die 'Usage: dotfiles control wifi|bluetooth|audio' 2 ;;
	esac
}

system_command() {
	case "${1:-}" in
	lock) system_lock ;;
	wake) system_wake ;;
	update) system_update ;;
	timezone | tz-select) system_timezone ;;
	power-menu | power) power_menu ;;
	*) die 'Usage: dotfiles system lock|wake|update|timezone|power-menu' 2 ;;
	esac
}

window_command() {
	case "${1:-}" in
	close-all) window_close_all ;;
	pop) window_pop ;;
	*) die 'Usage: dotfiles window close-all|pop' 2 ;;
	esac
}

workspace_command() {
	case "${1:-}" in
	layout-toggle) workspace_layout_toggle ;;
	monitor-scaling-cycle)
		shift
		monitor_scaling_cycle "$@"
		;;
	*) die 'Usage: dotfiles workspace layout-toggle|monitor-scaling-cycle' 2 ;;
	esac
}

brightness_command() {
	local kind="${1:-}"
	[[ -n $kind ]] || die 'Usage: dotfiles brightness display|keyboard ...' 2
	shift

	case "$kind" in
	display) brightness_display "$@" ;;
	keyboard) brightness_keyboard "$@" ;;
	*) die 'Usage: dotfiles brightness display|keyboard ...' 2 ;;
	esac
}

audio_command() {
	case "${1:-}" in
	input-mute) audio_input_mute ;;
	output-switch) audio_output_switch ;;
	*) die 'Usage: dotfiles audio input-mute|output-switch' 2 ;;
	esac
}

voxtype_command() {
	case "${1:-}" in
	status) voxtype_status ;;
	config) voxtype_config ;;
	model) voxtype_model ;;
	*) die 'Usage: dotfiles voxtype status|config|model' 2 ;;
	esac
}

main() {
	local command_name="${1:-help}"
	shift || true

	case "$command_name" in
	help | -h | --help) show_help "$@" ;;
	apps) show_managed_apps ;;
	diff) managed_chezmoi diff "$@" ;;
	apply) managed_chezmoi apply "$@" ;;
	menu) menu_command "$@" ;;
	restart) restart_service "$@" ;;
	reset) reset_command "$@" ;;
	screensaver) screensaver_command "$@" ;;
	open-app) open_app "$@" ;;
	open-or-focus) launch_or_focus "$@" ;;
	open-tui) launch_tui "$@" ;;
	open-or-focus-tui) launch_or_focus_tui "$@" ;;
	open-web-app) launch_webapp "$@" ;;
	open-or-focus-web-app) launch_or_focus_webapp "$@" ;;
	open-or-focus-browser) launch_or_focus_browser "$@" ;;
	create-web-app) create_web_app "$@" ;;
	create-tui-app) create_tui_app "$@" ;;
	open-browser) launch_browser "$@" ;;
	edit) launch_editor "$@" ;;
	set) set_default "$@" ;;
	shell-auto-complete) shell_auto_complete_command "$@" ;;
	capture) capture_command "$@" ;;
	toggle) toggle_command "$@" ;;
	status) status_command "$@" ;;
	control) control_command "$@" ;;
	system) system_command "$@" ;;
	window) window_command "$@" ;;
	workspace) workspace_command "$@" ;;
	brightness) brightness_command "$@" ;;
	audio) audio_command "$@" ;;
	voxtype) voxtype_command "$@" ;;
	osd) swayosd_client "$@" ;;
	walker) launch_walker "$@" ;;
	input) menu_input "$@" ;;
	open-floating-terminal) launch_floating_terminal "$@" ;;
	keybindings) show_keybindings ;;
	internal-terminal-cwd) cmd_terminal_cwd ;;
	complete) completion_command "$@" ;;
	*) die "Unknown dotfiles command: $command_name. Run: dotfiles help" 2 ;;
	esac
}

main "$@"
