# Changes require a restart to take effect.

# Install other terminals via Install > Terminal
export TERMINAL=xdg-terminal-exec

# Use code for VSCode
export EDITOR=nvim
export NVIM_NOTTYFAST=1

# Runtime defaults changed by `dotfiles set` live outside chezmoi.
[[ -f ~/.config/dotfiles/defaults.env ]] && source ~/.config/dotfiles/defaults.env

# Use a custom directory for screenshots (remember to make the directory!)
# export DOTFILES_SCREENSHOT_DIR="$HOME/Pictures/Screenshots"

# Use a custom directory for screenrecordings (remember to make the directory!)
# export DOTFILES_SCREENRECORD_DIR="$HOME/Videos/Screencasts"
